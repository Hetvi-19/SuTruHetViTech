{
  "entities": {
    "HistoryItem": {
      "title": "History Item",
      "description": "A record of a user's search or prediction activity.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "profileId": { "type": "string", "description": "The specific profile ID (self or family member ID)." },
        "type": { "type": "string", "description": "The type of activity (prediction, advice, diet, firstaid, medicine-prediction, report-analysis)." },
        "query": { "type": "string", "description": "The user's query or symptoms." },
        "result": { "type": "string", "description": "The AI's response (JSON stringified)." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the activity occurred." }
      },
      "required": ["uid", "profileId", "type", "query", "result", "timestamp"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Additional details about the user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "displayName": { "type": "string", "description": "The user's full name." },
        "email": { "type": "string", "description": "The user's email address." },
        "age": { "type": "number", "description": "The user's age." },
        "gender": { "type": "string", "enum": ["male", "female", "other"], "description": "The user's gender." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role (user or admin)." },
        "medicalHistory": { "type": "string", "description": "Brief medical history or allergies." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "displayName", "email", "age", "gender", "createdAt"]
    },
    "FamilyMember": {
      "title": "Family Member",
      "description": "A family member's profile linked to a primary user.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string", "description": "The primary user's ID." },
        "name": { "type": "string", "description": "The family member's name." },
        "age": { "type": "number", "description": "The family member's age." },
        "gender": { "type": "string", "description": "The family member's gender." },
        "relation": { "type": "string", "description": "Relation to the primary user." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the member was added." }
      },
      "required": ["ownerId", "name", "age", "gender", "relation", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in a chat conversation with the AI Assistant.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "profileId": { "type": "string", "description": "The specific profile ID (self or family member ID)." },
        "role": { "type": "string", "enum": ["user", "ai"], "description": "Who sent the message." },
        "text": { "type": "string", "description": "The content of the message." },
        "fileName": { "type": "string", "description": "Optional name of an uploaded file." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["uid", "profileId", "role", "text", "timestamp"]
    }
  },
  "firestore": {
    "/history/{historyId}": {
      "schema": "HistoryItem",
      "description": "Collection of user activity history."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    },
    "/family/{memberId}": {
      "schema": "FamilyMember",
      "description": "Collection of family members."
    },
    "/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "Collection of chat messages with the AI Assistant."
    }
  }
}
